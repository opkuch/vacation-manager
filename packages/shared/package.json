{
  "name": "@vm/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared API contract (types, Zod schemas, routes, errors) for the API and Web apps",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no lint configured for shared)\"",
    "test": "echo \"(no tests for shared)\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
