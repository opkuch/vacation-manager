# ---------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# These values are consumed by docker-compose and injected into each service,
# so the whole stack is reproducible on any machine with Docker installed.
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=vacation
POSTGRES_PASSWORD=vacation_dev_pw
POSTGRES_DB=vacation_manager
POSTGRES_PORT=5433

# --- API (commoneventframework dev server) ---
API_PORT=8888
# Connection string the API uses to reach Postgres. Host `db` is the compose
# service name (Docker full stack). For hybrid local dev, override in `.env.local`
# with `localhost` — see `.env.local.example`.
DATABASE_URL=postgresql://vacation:vacation_dev_pw@db:5432/vacation_manager
# Secret used to sign JWTs. Override with a strong value outside local dev.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
# Set to true when serving over HTTPS in production.
COOKIE_SECURE=false
# Allowed browser origin for CORS (read by the CEF Response wrapper).
FRONT_END_URL=http://localhost:8080

# --- Web (Vue + Vite) ---
WEB_PORT=8080
# API base path. The browser always calls the same origin under `/api`, which
# nginx (in Docker) and the Vite dev server both reverse-proxy to the API.
# This avoids CORS entirely. Leave as `/api` unless the API is hosted elsewhere.
VITE_API_URL=/api
