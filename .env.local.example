# ---------------------------------------------------------------------------
# Hybrid local dev: Postgres in Docker, API + web via `pnpm dev`.
# Copy to `.env.local` (`cp .env.local.example .env.local`) — it overrides `.env`.
# ---------------------------------------------------------------------------

# Host must be `localhost` when the API runs outside Docker (`db` only works in compose).
# Port matches `POSTGRES_PORT` in `.env` (5433 avoids clashing with a local PostgreSQL on 5432).
DATABASE_URL=postgresql://vacation:vacation_dev_pw@localhost:5433/vacation_manager
# Vite dev server origin (used for CORS).
FRONT_END_URL=http://localhost:5173
